# ============================================================
# 美國總經數據追蹤系統 — 環境變數範本
# 使用方式：
#   1. 將本檔案複製並重新命名為 .env
#   2. 填入你自己的金鑰
#   3. 確保 .env 已加入 .gitignore（絕對不要 commit 真實金鑰！）
# ============================================================

# FRED API 金鑰
# 申請網址：https://research.stlouisfed.org/useraccount/apikeys
FRED_API_KEY=??

# Notion Integration Token（ntn_ 開頭）
# 建立位置：https://www.notion.so/my-integrations
NOTION_TOKEN=??

# Notion 資料庫 ID（32 位英數字串，從資料庫 URL 取得）
# 取得方式：開啟資料庫頁面 → 複製網址中 / 與 ? 之間的字串
NOTION_DATABASE_ID=your_32_character_database_id_here

# ── 選用：Email 通知（需要 Gmail App Password）──────────────
# GMAIL_ADDRESS=your_gmail@gmail.com
# GMAIL_APP_PASSWORD=your_app_password
